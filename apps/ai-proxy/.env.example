# Proxy de IA de Abril — variables de entorno (SOLO en el servidor)
# Copia a `.env` (que está en .gitignore) o expórtalas antes de arrancar.
#
# 🔒 La key de DeepSeek vive AQUÍ, en el servidor. NUNCA en la app:
#    lo que va en un bundle de Expo es legible con el APK (ficha §24.1).

DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-v4-pro
PORT=8787
